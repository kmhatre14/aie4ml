Copyright (C) 2026, Advent lab

mm2s -- DDR -> PLIO_ifm streaming data mover (memory_stream deployment mode).

Design: {{ project_name }} ({{ in_feat }}->{{ out_feat }}, {{ n_ifm }} IFM PLIO).

PING-PONG DOUBLE BUFFERING: each iteration is staged into one of two on-chip buffers;

{% if enable_pl_timing %}
PL timing on: mm2s emits one-beat axis event pulses (iter0 send window) to the shared
tick_gen CU (sc=-wired), which owns the single free-running counter.
{% endif %}
*/

#include <ap_int.h>
#include <hls_stream.h>
#include <ap_axi_sdata.h>

static const int N_IFM_STREAMS = {{ n_ifm }};

// One iteration's per-stream rows = (size_in/16)/N_IFM_STREAMS. Ping-pong buffers
// are sized for a single iteration, independent of n_iter.
static const int MAX_IFM_512_PER_STREAM = {{ ifm_per_stream }};
{% if enable_pl_timing %}
// One-beat timing event pulse to the shared tick_gen CU (sc=-wired). Data is
// irrelevant -- the pulse's arrival is what tick_gen timestamps.
using ev_t = ap_axis<32, 0, 0, 0>;
static void emit_event(hls::stream<ev_t>& ev) {
#pragma HLS inline
    ev_t p;
    p.data = 1; p.keep = -1; p.last = 1;
    ev.write(p);
}
{% endif %}

// Load one iteration from DDR into the per-stream ping-pong buffer, de-striped.
// DDR is read contiguously (good bursts); word i lands in buf[i % N][i / N].
static void load_ddr(ap_uint<512>* mem,
                     ap_uint<512> buf[N_IFM_STREAMS][MAX_IFM_512_PER_STREAM],
                     int rows_per_stream, int iter_idx, bool enable) {
#pragma HLS inline off
    if (enable) {
        const int total = rows_per_stream * N_IFM_STREAMS;
        const int base  = iter_idx * total;
        for (int i = 0; i < total; i++) {
        #pragma HLS PIPELINE II=1
            ap_uint<512> w = mem[base + i];
            int row_slot   = i / N_IFM_STREAMS;
            int stream_sel = i % N_IFM_STREAMS;
{% for s in range(n_ifm) %}
            {{ "if" if loop.first else "} else if" }} (stream_sel == {{ s }}) {
                buf[{{ s }}][row_slot] = w;
{% endfor %}
            }
        }
    }
}

// Send one staged iteration to the {{ n_ifm }} PLIO stream(s). Per row, push the 4 x 128b
// beats of each stream's 512-bit word; TLAST on the last beat of the iteration.
static void send_plio(ap_uint<512> buf[N_IFM_STREAMS][MAX_IFM_512_PER_STREAM],
{% for s in range(n_ifm) %}
                      hls::stream<ap_axis<128, 0, 0, 0>>& s_out_{{ s }},
{% endfor %}
                      int rows_per_stream, bool enable{% if enable_pl_timing %}, bool is_iter0,
                      hls::stream<ev_t>& ev_first_send,
                      hls::stream<ev_t>& ev_last_send{% endif %}) {
#pragma HLS inline off
    if (enable) {
{% if enable_pl_timing %}
        if (is_iter0) { emit_event(ev_first_send); }   // first PLIO_ifm beat of iter0
{% endif %}
        for (int row = 0; row < rows_per_stream; row++) {
{% for s in range(n_ifm) %}
            ap_uint<512> w{{ s }} = buf[{{ s }}][row];
{% endfor %}

            for (int j = 0; j < 4; j++) {
            #pragma HLS PIPELINE II=1
                ap_uint<1> tlast = (row == rows_per_stream - 1 && j == 3) ? 1 : 0;
{% for s in range(n_ifm) %}
                ap_axis<128, 0, 0, 0> x{{ s }};
                x{{ s }}.data = w{{ s }}.range((j + 1) * 128 - 1, j * 128); x{{ s }}.keep = -1; x{{ s }}.last = tlast;
                s_out_{{ s }}.write(x{{ s }});
{% endfor %}
            }
        }
{% if enable_pl_timing %}
        if (is_iter0) { emit_event(ev_last_send); }    // last PLIO_ifm beat of iter0
{% endif %}
    }
}

extern "C" {

// mem_in  : 512-bit AXI-M (DDR), holds n_iter x size_in 32-bit words back-to-back.
// s_out_* : 128-bit AXI-stream to AIE PLIO_ifm_* (plio_128_bits).
// size_in : 32-bit words per iteration, summed across all {{ n_ifm }} stream(s).
// n_iter  : number of iterations to run.
void mm2s(ap_uint<512>* mem_in,
{% for s in range(n_ifm) %}
          hls::stream<ap_axis<128, 0, 0, 0>>& s_out_{{ s }},
{% endfor %}
{% if enable_pl_timing %}
          hls::stream<ev_t>& ev_first_send,
          hls::stream<ev_t>& ev_last_send,
{% endif %}
          int size_in, int n_iter) {
#pragma HLS INTERFACE m_axi port=mem_in offset=slave bundle=gmem_in \
    max_read_burst_length=16 num_read_outstanding=16
{% for s in range(n_ifm) %}
#pragma HLS INTERFACE axis port=s_out_{{ s }}
{% endfor %}
{% if enable_pl_timing %}
#pragma HLS INTERFACE axis port=ev_first_send
#pragma HLS INTERFACE axis port=ev_last_send
{% endif %}
#pragma HLS INTERFACE s_axilite port=mem_in   bundle=control
#pragma HLS INTERFACE s_axilite port=size_in  bundle=control
#pragma HLS INTERFACE s_axilite port=n_iter   bundle=control
#pragma HLS INTERFACE s_axilite port=return   bundle=control

    // Two ping-pong buffers, each one iteration deep. Partition on the stream
    // dim so the {{ n_ifm }} stream(s) are independent banks (load writes distinct
    // banks round-robin, send reads all of them in parallel).
    ap_uint<512> buff0[N_IFM_STREAMS][MAX_IFM_512_PER_STREAM];
    ap_uint<512> buff1[N_IFM_STREAMS][MAX_IFM_512_PER_STREAM];
    #pragma HLS ARRAY_PARTITION variable=buff0 complete dim=1
    #pragma HLS ARRAY_PARTITION variable=buff1 complete dim=1
    #pragma HLS bind_storage variable=buff0 type=RAM_2P impl={{ pl_mem_impl }}
    #pragma HLS bind_storage variable=buff1 type=RAM_2P impl={{ pl_mem_impl }}

    const int rows_per_stream = (size_in / 16) / N_IFM_STREAMS;

    // Trip count n_iter+1: load leads by one iteration, send trails by one.
    for (int rd = 0; rd < n_iter + 1; rd++) {
        // Default each flag to 0; set to 1 when its condition holds.
        bool load_en    = 0;
        bool send_en    = 0;
{% if enable_pl_timing %}
        bool send_iter0 = 0;
{% endif %}
        if (rd < n_iter) { load_en    = 1; }   // load iteration rd
        if (rd > 0)      { send_en    = 1; }   // send iteration rd-1 (staged last round)
{% if enable_pl_timing %}
        if (rd == 1)     { send_iter0 = 1; }   // the iteration being sent is iter0
{% endif %}

        if (rd % 2 == 0) {
            load_ddr (mem_in, buff0, rows_per_stream, rd, load_en);
            send_plio(buff1,
{% for s in range(n_ifm) %}
                      s_out_{{ s }},
{% endfor %}
                      rows_per_stream, send_en{% if enable_pl_timing %}, send_iter0, ev_first_send, ev_last_send{% endif %});
        } else {
            load_ddr (mem_in, buff1, rows_per_stream, rd, load_en);
            send_plio(buff0,
{% for s in range(n_ifm) %}
                      s_out_{{ s }},
{% endfor %}
                      rows_per_stream, send_en{% if enable_pl_timing %}, send_iter0, ev_first_send, ev_last_send{% endif %});
        }
    }
}

}
